VERSION 1.0 CLASS
BEGIN
  MultiUse = -1  ' True
END
Attribute VB_Name = "ThisWorkbook"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = True
Option Explicit

' ==========================================================
' ThisWorkbook: vbaWord Main Dispatcher with CommandBar Menu
' Author: Azi-lzb
' Description: Creates a custom menu in the Excel legacy menu bar (Add-ins).
' ==========================================================

Private Sub Workbook_Open()
    Call CreateCustomMenu
End Sub

Private Sub Workbook_Activate()
    Call CreateCustomMenu
End Sub

Private Sub Workbook_Deactivate()
    On Error Resume Next
    Application.CommandBars("Worksheet menu bar").Controls("vbaWordЙЄОп(&S)").Delete
    On Error GoTo 0
End Sub

' --- ДДНЈздЖЈвхВЫЕЅ (ИНМгАДХЅ) ---
Public Sub CreateCustomMenu()
    Dim ToolMenu As Object
    Dim NewMenu As Object
    
    With Application.CommandBars("Worksheet menu bar")
        ' ЯШЩОГ§вбДцдкЕФВЫЕЅЗРжЙжиИД
        On Error Resume Next
        .Controls("vbaWordЙЄОп(&S)").Delete
        On Error GoTo 0
        
        ' ВщевЁАЙЄОпЁБВЫЕЅЮЛжУ (ID 30007 ЭЈГЃЪЧЁАЙЄОп(&T)ЁБ)
        Set ToolMenu = .FindControl(ID:=30007)
        
        If ToolMenu Is Nothing Then
            Set NewMenu = .Controls.Add(Type:=10) ' msoControlPopup
        Else
            Set NewMenu = .Controls.Add(Type:=10, before:=ToolMenu.Index)
        End If
        
        With NewMenu
            .Caption = "vbaWordЙЄОп(&S)"
            
            ' --- 1. ОЩЪНДАЬхЛузм ---
            With .Controls.Add(Type:=10)
                .Caption = "1. ОЩЪНДАЬхЛузм"
                With .Controls.Add(Type:=1) ' msoControlButton
                    .Caption = "1.1 ЛузмжС Excel (outputБэ)"
                    .OnAction = "extractWord.BatchSummarizeWordForms"
                End With
                With .Controls.Add(Type:=1)
                    .Caption = "1.2 ЛузмжС Word (аТЮФЕЕ)"
                    .OnAction = "extractToWord.SummarizeToNewWordDoc"
                End With
            End With
            
            ' --- 2. ФкШнПиМўЛузм ---
            With .Controls.Add(Type:=10)
                .Caption = "2. ФкШнПиМўЛузм"
                With .Controls.Add(Type:=1)
                    .Caption = "2.1 ЛузмжС Excel (output_ccБэ)"
                    .OnAction = "extractCCtoExcel.SummarizeContentControlsToExcel"
                End With
                With .Controls.Add(Type:=1)
                    .Caption = "2.2 ЛузмжС Word (аТЮФЕЕ)"
                    .OnAction = "extractCCtoWord.SummarizeCCToWord"
                End With
            End With
            
            ' --- 3. ЪОР§Ъ§ОнЩњГЩ (WordАц) ---
            With .Controls.Add(Type:=10)
                .Caption = "3. ЪОР§Ъ§ОнЩњГЩ"
                With .Controls.Add(Type:=1)
                    .Caption = "3.1 ЩњГЩОЩЪНДАЬхЪОР§"
                    .OnAction = "GenerateTestData.CreateSampleDocs"
                End With
                With .Controls.Add(Type:=1)
                    .Caption = "3.2 ЩњГЩФкШнПиМўЪОР§"
                    .OnAction = "GenerateCCTestData.CreateCCSampleDocs"
                End With
            End With
            
        End With
    End With
    
    Set ToolMenu = Nothing
    Set NewMenu = Nothing
End Sub
